# Alice Blue API credentials (fill after app approved). NEVER commit real values.
# App: "Trading". App Key/Secret/redirect = OAuth (developer portal).
# USER_ID + API_KEY = needed for pya3 session login (ANT web -> Apps -> API Key).
ALICE_USER_ID=
ALICE_API_KEY=
ALICE_APP_KEY=
ALICE_APP_SECRET=
ALICE_REDIRECT_URL=

# Upstox API (developer.upstox.com -> Apps). Has EXPIRED F&O historical candles.
# OAuth: open dialog -> redirect carries ?code= -> exchange for access_token.
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URL=

# Angel One SmartAPI (https://smartapi.angelbroking.com -> My Profile)
# API Key from "My Smart API & Apps" (Trading app). NEVER commit real values.
ANGELONE_API_KEY=
ANGELONE_CLIENT_CODE=
ANGELONE_PIN=
# TOTP secret: the base32 seed shown when you Enable TOTP (NOT the 6-digit code)
ANGELONE_TOTP_SECRET=

# Kaggle API (https://www.kaggle.com/settings -> Create New Token -> kaggle.json)
KAGGLE_USERNAME=
KAGGLE_KEY=

# Paths
DATA_DIR=./data
LAKE_DIR=./data/lake
